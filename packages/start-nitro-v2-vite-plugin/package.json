{
  "name": "@solidjs/vite-plugin-nitro-2",
  "description": "Nitro v2 plugin for development with SolidStart 2.0",
  "version": "0.3.2-beta.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidjs/solid-start.git",
    "directory": "packages/start-nitro-v2-vite-plugin"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "typecheck:dist": "pnpm build && pnpx @arethetypeswrong/cli --pack . --profile esm-only"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.js"
    }
  },
  "dependencies": {
    "nitropack": "^2.13.1"
  },
  "devDependencies": {
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "vite": "^7 || ^8"
  }
}
