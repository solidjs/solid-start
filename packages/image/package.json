{
  "name": "@solidjs/image",
  "version": "0.1.0",
  "type": "module",
  "types": "./env.d.ts",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "typecheck:dist": "pnpm build && pnpx @arethetypeswrong/cli --pack . --profile esm-only"
  },
  "files": [
    "dist",
    "env.d.ts",
    "package.json",
    "README.md"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./vite": "./dist/vite.js",
    "./env": "./env.d.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.js",
      "./vite": "./dist/vite.js",
      "./env": "./env.d.ts"
    }
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "solid-js": "^1.9.9",
    "tsdown": "^0.9.0",
    "vite": "^7.1.10"
  },
  "peerDependencies": {
    "solid-js": "^1.9.9",
    "vite": "^7"
  },
  "engines": {
    "node": ">=22"
  }
}
